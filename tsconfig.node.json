{
	"extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
	"include": [
		"electron.vite.config.*",
		"src/main/**/*",
		"src/preload/**/*",
		"src/utils/**/*",
		"src/shared/**/*"
	],
	"compilerOptions": {
		"composite": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"types": ["node", "electron-vite/node"]
	}
}
